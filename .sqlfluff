[sqlfluff]
dialect = postgres
templater = placeholder
max_line_length = 120
# LT05: long-line wrapping is handled manually.
# RF06: identifiers are quoted deliberately — "$(NS)" is substituted verbatim.
# PG01: indexes are created on empty tables at deploy time; CONCURRENTLY does
#       not apply to this greenfield namespace deployment.
exclude_rules = LT05, RF06, PG01

[sqlfluff:templater:placeholder]
param_regex = \$\((?P<param_name>\w+)\)
NS = ns

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = lower
